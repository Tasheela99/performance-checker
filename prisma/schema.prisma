generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                        @id @default(uuid()) @db.Uuid
  name                  String                        @db.VarChar(255)
  email                 String                        @unique @db.VarChar(255)
  passwordHash          String                        @map("password_hash") @db.VarChar(255)
  role                  Role                          @default(employee)
  department            String?                       @db.VarChar(255)
  position              String?                       @db.VarChar(255)
  avatar                String?                       @db.VarChar(500)
  
  // Email verification fields
  isVerified            Boolean                       @default(false) @map("is_verified")
  verificationToken     String?                       @unique @map("verification_token") @db.VarChar(255)
  verificationTokenExpiry DateTime?                   @map("verification_token_expiry") @db.Timestamptz(6)
  
  // Terms acceptance
  acceptedTerms         Boolean                       @default(false) @map("accepted_terms")
  acceptedTermsAt       DateTime?                     @map("accepted_terms_at") @db.Timestamptz(6)
  
  createdAt             DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  appraisalReviews      AppraisalReview[]
  appraisalSubmissions  AppraisalSubmission[]
  createdTemplates      AppraisalTemplate[]           @relation("TemplateCreator")
  passwordResetTokens   PasswordResetToken[]
  templateAssignments   TemplateAssignment[]
  performanceTracking   OfficerPerformanceTracking?

  @@index([email])
  @@index([role])
  @@index([verificationToken])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model AppraisalTemplate {
  id          String                @id @default(uuid()) @db.Uuid
  title       String                @db.VarChar(255)
  description String?
  period      String                @db.VarChar(100)
  deadline    DateTime              @db.Timestamptz(6)
  createdById String                @map("created_by") @db.Uuid
  status      TemplateStatus        @default(draft)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  submissions AppraisalSubmission[]
  createdBy   User                  @relation("TemplateCreator", fields: [createdById], references: [id])
  goals       Goal[]
  assignments TemplateAssignment[]

  @@index([createdById])
  @@index([status])
  @@map("appraisal_templates")
}

model Goal {
  id            String            @id @default(uuid()) @db.Uuid
  templateId    String            @map("template_id") @db.Uuid
  title         String            @db.VarChar(255)
  description   String?
  category      String            @db.VarChar(100)
  section       PerformanceSection @default(tasks)
  weightage     Int
  goalOrder     Int               @map("goal_order")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  goalResponses GoalResponse[]
  goalReviews   GoalReview[]
  template      AppraisalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([section])
  @@map("goals")
}

model TemplateAssignment {
  id         String            @id @default(uuid()) @db.Uuid
  templateId String            @map("template_id") @db.Uuid
  employeeId String            @map("employee_id") @db.Uuid
  assignedAt DateTime          @default(now()) @map("assigned_at") @db.Timestamptz(6)
  employee   User              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template   AppraisalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, employeeId])
  @@index([templateId])
  @@index([employeeId])
  @@map("template_assignments")
}

model AppraisalSubmission {
  id            String            @id @default(uuid()) @db.Uuid
  templateId    String            @map("template_id") @db.Uuid
  employeeId    String            @map("employee_id") @db.Uuid
  employeeName  String            @map("employee_name") @db.VarChar(255)
  status        SubmissionStatus  @default(pending)
  submittedAt   DateTime?         @map("submitted_at") @db.Timestamptz(6)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  review        AppraisalReview?
  employee      User              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template      AppraisalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  goalResponses GoalResponse[]

  @@unique([templateId, employeeId])
  @@index([templateId])
  @@index([employeeId])
  @@index([status])
  @@map("appraisal_submissions")
}

model GoalResponse {
  id           String              @id @default(uuid()) @db.Uuid
  submissionId String              @map("submission_id") @db.Uuid
  goalId       String              @map("goal_id") @db.Uuid
  response     String?
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  goal         Goal                @relation(fields: [goalId], references: [id], onDelete: Cascade)
  submission   AppraisalSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, goalId])
  @@index([submissionId])
  @@index([goalId])
  @@map("goal_responses")
}

model AppraisalReview {
  id             String              @id @default(uuid()) @db.Uuid
  submissionId   String              @unique @map("submission_id") @db.Uuid
  reviewerId     String              @map("reviewer_id") @db.Uuid
  reviewerName   String              @map("reviewer_name") @db.VarChar(255)
  taskScore      Int                 @map("task_score") @default(0)
  competencyScore Int                @map("competency_score") @default(0)
  overallScore   Int                 @map("overall_score")
  performanceClassification String   @map("performance_classification") @db.VarChar(100) @default("NEEDS_CRITICAL_IMPROVEMENT")
  overallComment String?             @map("overall_comment")
  reviewedAt     DateTime            @default(now()) @map("reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  reviewer       User                @relation(fields: [reviewerId], references: [id])
  submission     AppraisalSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  goalReviews    GoalReview[]

  @@index([submissionId])
  @@index([reviewerId])
  @@index([overallScore])
  @@index([performanceClassification])
  @@map("appraisal_reviews")
}

model GoalReview {
  id        String          @id @default(uuid()) @db.Uuid
  reviewId  String          @map("review_id") @db.Uuid
  goalId    String          @map("goal_id") @db.Uuid
  score     Int
  feedback  String?
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  goal      Goal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  review    AppraisalReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, goalId])
  @@index([reviewId])
  @@index([goalId])
  @@map("goal_reviews")
}

model OfficerPerformanceTracking {
  id                           String   @id @default(uuid()) @db.Uuid
  officerId                    String   @unique @map("officer_id") @db.Uuid
  consecutiveExcellentYears    Int      @map("consecutive_excellent_years") @default(0)
  totalIncrements              Int      @map("total_increments") @default(0)
  eligibleForPresidentialAward Boolean  @map("eligible_for_presidential_award") @default(false)
  lastExcellentYear            String?  @map("last_excellent_year") @db.VarChar(10)
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  officer                      User     @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@index([officerId])
  @@index([consecutiveExcellentYears])
  @@index([eligibleForPresidentialAward])
  @@map("officer_performance_tracking")
}

enum Role {
  admin
  manager
  employee
}

enum TemplateStatus {
  draft
  published
  closed
}

enum SubmissionStatus {
  pending
  inProgress @map("in-progress")
  submitted
  reviewed
}

enum PerformanceSection {
  tasks
  competencies
}
